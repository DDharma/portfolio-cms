# Supabase Configuration
# Get these values from your Supabase project dashboard (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (keep this secret, only used on the server)
# Get this from Project Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret for custom authentication
# Use a random string, minimum 32 characters
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your-random-jwt-secret-min-32-chars

# Optional: disable the public /setup admin-creation flow.
# Defaults to enabled. Set to "false" only on hardened deployments where the
# first admin is seeded directly via SQL — the /setup route will then render
# a "disabled" message and POST /api/auth/register will return 403.
# NEXT_PUBLIC_ENABLE_ONBOARDING=true
